# shellcheck shell=bash
# rust-feh direnv entrypoint.
# Shared workspace secrets come from parent ~/Apps/.envrc + .envrc.local.
# Keep workspace-wide model API keys parent-only; this repo's .envrc.local is for
# project-specific overrides/secrets only.
# Run `direnv allow` after editing this file or .envrc.local.

source_up

# Local scripts (validate-*, sudo-askpass helpers)
PATH_add scripts

# Rust toolchain (rustup)
if [[ -d "${HOME}/.cargo/bin" ]]; then
  PATH_add "${HOME}/.cargo/bin"
fi

# Optional: GUI askpass for sudo in dev sessions
if [[ -x "${HOME}/.local/bin/sudo-askpass" ]]; then
  export SUDO_ASKPASS="${HOME}/.local/bin/sudo-askpass"
fi

# Load project-local secrets and machine overrides last so they can override/add tokens.
source_env_if_exists .envrc.local
