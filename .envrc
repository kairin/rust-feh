# rust-feh — direnv project environment
# Inherits GH/HF/Codacy account tokens from parent Apps/ via source_up.
# Project-level Codacy overrides live in .envrc.local (gitignored).

source_up

source_env_if_exists .envrc.local

# Local scripts (validate-*, sudo-askpass helpers)
PATH_add scripts

# Rust toolchain (rustup)
if [[ -d "${HOME}/.cargo/bin" ]]; then
  PATH_add "${HOME}/.cargo/bin"
fi

# Optional: GUI askpass for sudo in dev sessions
if [[ -x "${HOME}/.local/bin/sudo-askpass" ]]; then
  export SUDO_ASKPASS="${HOME}/.local/bin/sudo-askpass"
fi