# shellcheck shell=bash
# Copy to .envrc.local and adjust token file paths for this machine.
#   cp .envrc.local.example .envrc.local
# Then: direnv allow
#
# .envrc.local is gitignored — never commit API tokens or passwords.
# Parent Apps/.envrc.local already loads GH, HF, and Codacy account tokens.

load_secret() {
  local var_name="$1"
  local token_file="$2"
  local value

  if [ -r "$token_file" ]; then
    value="$(LC_ALL=C tr -d '\000\r\n' < "$token_file")"
    export "$var_name=$value"
  fi
}

# --- Codacy CLI (project-level overrides) ---
# Create the project token in Codacy UI, then save it to the path below.
# Clear parent Apps default (my-comfyui-nodes) before loading this project's token.
unset CODACY_PROJECT_TOKEN
load_secret CODACY_PROJECT_TOKEN "/home/kkk/.codacy/kairin-rust-feh.project-token"
export CODACY_ORGANIZATION_PROVIDER="gh"
export CODACY_USERNAME="kairin"
export CODACY_PROJECT_NAME="rust-feh"

# --- Optional overrides ---
# export RUST_LOG="rust_feh=debug"
# export DISPLAY=":0"